---
import Base from "../layouts/Base.astro";
import StatTile from "../components/StatTile.astro";
import DivergingColumns from "../components/DivergingColumns.astro";
import { meta, termsAgg, justiceIndex, termList, casesForTerm, pendingCases, byMnemonic, forecasts } from "../lib/data.js";
import { num, caseTitle, url } from "../lib/format.js";

const m = meta();
const agg = termsAgg();
const points = agg
  .filter((t) => t.liberal_share != null)
  .map((t) => ({ x: t.term, value: t.liberal_share, n: t.liberal + t.conservative }));

const lastTerm = m.counts.last_term;
const latestTerm = termList().at(-1); // may exceed SCDB coverage (provisional ingest)
const sitting = justiceIndex().filter((j) => j.last_term === lastTerm);
const justiceOf = byMnemonic();

const latestCases = casesForTerm(latestTerm)
  .filter((c) => c.dates?.decided)
  .sort((a, b) => String(b.dates.decided).localeCompare(String(a.dates.decided)))
  .slice(0, 8);

const pending = pendingCases();
const arguedPending = pending
  .filter((p) => p.dates?.argued)
  .sort((a, b) => String(a.dates.argued).localeCompare(String(b.dates.argued)));
const grantedPending = pending
  .filter((p) => !p.dates?.argued)
  .sort((a, b) => String(b.dates?.granted ?? "").localeCompare(String(a.dates?.granted ?? "")));

const forecastOf = forecasts();

const authorLink = (mnemonic) => {
  const j = typeof mnemonic === "string" ? justiceOf.get(mnemonic) : null;
  return j ? { href: url(`/justices/${j.slug}`), name: j.name } : null;
};
const clip = (s, n) => (s && s.length > n ? s.slice(0, n).trimEnd() + "…" : s);
---

<Base title="Home" description="Every U.S. Supreme Court judgment, every justice, every vote — 1791 to today.">
  <p class="eyebrow">A statistical model of the Supreme Court</p>
  <h1>Every judgment. Every justice. Every vote.</h1>
  <p class="lede">
    The full voting record of the Supreme Court of the United States — {num(m.counts.cases)} cases
    across terms {m.counts.first_term}–{m.counts.last_term}, from the Supreme Court Database —
    as a browsable dataset headed toward a forecasting model.
  </p>

  <div class="kpis">
    <StatTile label="Cases decided" value={num(m.counts.cases)} sub={`${num(m.counts.cases_modern)} modern · ${num(m.counts.cases_legacy)} legacy`} />
    <StatTile label="Individual justice votes" value={num(m.counts.vote_records)} />
    <StatTile label="Justices" value={m.counts.justices} sub="40 with curated biographies" />
    <StatTile label="Natural courts" value={m.counts.natural_courts} sub={`${m.counts.first_term}–${m.counts.last_term}`} />
  </div>

  <section class="card viz">
    <h3>The Court's direction, term by term</h3>
    <p class="viz-sub">
      Share of orally-decided cases coded liberal each term (SCDB decision direction);
      columns above the 50% line mark majority-liberal terms. Hover any term for detail.
    </p>
    <DivergingColumns
      points={points}
      nLabel="directional decisions"
      xLabel="term"
      caption="Share of liberal decisions by Supreme Court term"
    />
  </section>

  {latestCases.length > 0 && (
    <>
      <h2>Latest decisions</h2>
      <p class="lede" style="margin-bottom:10px">
        The newest rulings in the dataset{latestTerm > lastTerm ? " — provisional records until the next SCDB release" : ""}.
      </p>
      <table class="data">
        <thead>
          <tr><th>Decided</th><th>Case</th><th class="n">Vote</th><th>Majority opinion</th></tr>
        </thead>
        <tbody>
          {latestCases.map((c) => {
            const d = c.decision ?? {};
            const author = authorLink(c.opinions?.majority_author);
            return (
              <tr>
                <td class="n">{c.dates.decided}</td>
                <td>
                  <a href={url(`/cases/${c.id}`)}>{caseTitle(c.name)}</a>
                  {c.question && <div class="stat-sub" style="max-width:62ch">{clip(c.question, 150)}</div>}
                </td>
                <td class="n">
                  {d.majority_votes != null && d.minority_votes != null
                    ? `${d.majority_votes}–${d.minority_votes}`
                    : "—"}
                </td>
                <td>{author ? <a href={author.href}>{author.name}</a> : "—"}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
      <p style="font-size:13px; margin-top:8px">
        <a href={url(`/terms/${latestTerm}`)}>All {latestTerm} term cases →</a>
      </p>
    </>
  )}

  {pending.length > 0 && (
    <>
      <h2>Awaiting decision</h2>
      <p class="lede" style="margin-bottom:10px">
        The live docket from Oyez: {arguedPending.length} argued, {grantedPending.length} granted
        and awaiting argument. Forecasts are calibrated reverse probabilities from the
        walk-forward-validated engine — <a href={url("/predict")}>full per-justice predictions →</a>
      </p>
      <table class="data">
        <thead>
          <tr><th>Case</th><th class="n">Forecast</th><th class="n">Status</th></tr>
        </thead>
        <tbody>
          {[...arguedPending, ...grantedPending].map((p) => {
            const fc = forecastOf.get(p.id);
            return (
              <tr>
                <td>
                  {p.oyez_url
                    ? <a href={p.oyez_url} target="_blank" rel="noopener">{caseTitle(p.name)}</a>
                    : caseTitle(p.name)}
                  <span class="stat-sub" style="margin-left:8px">{p.docket} · {p.term} term</span>
                  {p.question && <div class="stat-sub" style="max-width:66ch">{clip(p.question, 170)}</div>}
                </td>
                <td class="n" style="white-space:nowrap">
                  {fc
                    ? <span data-tip-value={`${Math.round(fc.prediction.p_reverse * 100)}% chance the Court disturbs the judgment below`}
                        data-tip-label={`expected reverse votes ${fc.prediction.expected_reverse_votes} of 9`}>
                        {Math.round(fc.prediction.p_reverse * 100)}% reverse
                      </span>
                    : "—"}
                </td>
                <td class="n" style="white-space:nowrap">
                  {p.dates?.argued ? `argued ${p.dates.argued}` : p.dates?.granted ? `granted ${p.dates.granted}` : "granted"}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </>
  )}

  <h2>The current court</h2>
  <div class="chips">
    {sitting.map((j) => (
      <a class="chip" href={url(`/justices/${j.slug}`)}>
        {j.party && <span class={`dot ${j.party === "Democratic" ? "lib" : "con"}`}></span>}
        <b>{j.name}</b>
      </a>
    ))}
  </div>

  <h2>Explore</h2>
  <div class="kpis">
    <a class="card" href={url("/justices")} style="text-decoration:none">
      <div class="stat-label">Justices</div>
      <div class="stat-value">Trajectories</div>
      <div class="stat-sub">Ideology over time, records, biographies</div>
    </a>
    <a class="card" href={url(`/terms/${latestTerm}`)} style="text-decoration:none">
      <div class="stat-label">Latest term</div>
      <div class="stat-value">{latestTerm}</div>
      <div class="stat-sub">
        {latestTerm > lastTerm ? "Provisional — live from Oyez/CourtListener" : "Dockets, splits, and outcomes"}
      </div>
    </a>
    <a class="card" href={url("/courts")} style="text-decoration:none">
      <div class="stat-label">Natural courts</div>
      <div class="stat-value">{m.counts.natural_courts}</div>
      <div class="stat-sub">Every stable bench since 1791</div>
    </a>
  </div>
</Base>
