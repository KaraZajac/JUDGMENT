---
import Base from "../layouts/Base.astro";
import StatTile from "../components/StatTile.astro";
import { pendingCases, forecasts, postArgumentForecasts, byMnemonic, scorecard } from "../lib/data.js";
import { caseTitle, fmtDate, pct, url } from "../lib/format.js";

const card = scorecard();
const scored = card?.scored ?? [];

const pending = pendingCases();
const forecastOf = forecasts();
const stage2Of = postArgumentForecasts();
const justiceOf = byMnemonic();
const pa = card?.post_argument ?? null;

const argued = pending.filter((p) => p.dates?.argued);
const unargued = pending.filter((p) => !p.dates?.argued);
const scheduled = unargued.filter((p) => p.dates?.scheduled_argument);

const ordered = [
  ...argued.sort((a, b) => String(a.dates.argued).localeCompare(String(b.dates.argued))),
  ...unargued.sort((a, b) =>
    String(a.dates?.scheduled_argument ?? "9999").localeCompare(String(b.dates?.scheduled_argument ?? "9999")) ||
    String(a.dates?.granted ?? "9999").localeCompare(String(b.dates?.granted ?? "9999"))),
];

const nextTermYear = Math.max(...pending.map((p) => p.term));
function firstMonday(year) {
  const first = new Date(Date.UTC(year, 9, 1));
  const offset = (8 - first.getUTCDay()) % 7;
  return new Date(Date.UTC(year, 9, 1 + offset));
}
const sittingStart = firstMonday(nextTermYear).toLocaleDateString("en-US", {
  weekday: "long", year: "numeric", month: "long", day: "numeric", timeZone: "UTC",
});

const statusOf = (p) =>
  p.dates?.argued ? `argued ${fmtDate(p.dates.argued)}`
  : p.dates?.scheduled_argument ? `argument set for ${fmtDate(p.dates.scheduled_argument)}`
  : p.dates?.granted ? `granted ${fmtDate(p.dates.granted)} · awaiting argument date`
  : "granted";

const topSplits = (fc, n = 3) =>
  Object.entries(fc?.prediction?.reverse_vote_distribution ?? {})
    .sort((a, b) => b[1] - a[1])
    .slice(0, n);

const clip = (s, n) => (s && s.length > n ? s.slice(0, n).trimEnd() + "…" : s);
---

<Base title="Predict" description="Calibrated forecasts for every pending Supreme Court case.">
  <p class="eyebrow">The model, live</p>
  <h1>Predictions</h1>
  <p class="lede">
    Calibrated probabilities for every granted-but-undecided case, from the
    walk-forward-validated engine in <code>models/</code>. Registration is staged:
    these <b>cert-stage</b> forecasts use only features knowable at grant — justice
    history including recent topic-level lean, hand-coded issue area and lower-court
    direction, party flags — validated at <b>67.9%</b> per-vote accuracy (Brier 0.207)
    over 1956–2024, outperforming the full-SCDB research configuration (66.8%). Each
    freezes on argument day; a separately scored <b>post-argument</b> stage re-registers
    argued cases with per-justice questioning features from the transcripts and the side
    the Solicitor General supports as amicus (walk-forward validated: <b>69.6%</b>
    per-vote, Brier 0.200 — rising to ~73% on SG-involved cases, whose supported side
    historically reverses 75.8% vs 42.3%). Every feature faces the same gate: question
    text was rejected twice; Segal–Cover scores, originating circuit, and
    dissent-below were tested and not adopted. Probabilities are isotonic-calibrated —
    details and limitations in
    <code>models/output/report-reverse.md</code>.
  </p>
  <p class="notice">
    <b>Why does everything lean "reverse"?</b> Certiorari selection: the Court takes
    cases largely to fix them, reversing ~70% in recent terms — so calibrated
    pre-argument forecasts start near that base rate, and the information is in the
    <i>ordering</i> and per-justice structure. Forecasts are conditional on a merits
    ruling (mootness/DIG off-ramps are outside the model). Issue areas and lower-court
    directions for pending cases are provisional hand-codings with documented bases
    (<code>models/pending_issues.yaml</code>, <code>models/pending_lc.yaml</code>);
    split distributions use the validated coalition model. Forecasts regenerate via
    <code>models/predict.py</code> only while a case awaits argument, then freeze; the
    scorer admits nothing that is not strictly ex-ante — a forecast file written on or
    after decision day is excluded from the track record, never scored.
  </p>

  <div class="kpis">
    <StatTile label="Pending cases" value={pending.length} sub={`${argued.length} argued · ${unargued.length} awaiting argument`} />
    <StatTile label="Argument dates set" value={scheduled.length} sub="from supremecourt.gov dockets" />
    <StatTile label={`Arguments resume (OT${nextTermYear})`} value={sittingStart.split(",")[0]} sub={sittingStart} />
  </div>

  <h2>Track record</h2>
  {scored.length > 0 ? (
    <>
      <div class="kpis">
        <StatTile label="Cases scored" value={card.summary.cases_scored} sub={`${card.awaiting_decision} still pending`} />
        <StatTile label="Case accuracy" value={pct(card.summary.case_accuracy, 1)} sub={`Brier ${card.summary.case_brier}`} />
        {card.summary.justice_vote_accuracy != null && (
          <StatTile label="Justice-vote accuracy" value={pct(card.summary.justice_vote_accuracy, 1)} sub={`${card.summary.justice_votes_scored} votes scored`} />
        )}
      </div>
      <div class="viz-scroll">
      <table class="data">
        <thead>
          <tr><th>Case</th><th class="n">Forecast</th><th>Outcome</th><th>Scored</th><th>Basis</th></tr>
        </thead>
        <tbody>
          {scored.map((s) => (
            <tr>
              <td><a href={url(`/cases/${s.id}`)}>{caseTitle(s.name)}</a></td>
              <td class="n">{pct(s.p_reverse)} reverse</td>
              <td>{s.outcome}</td>
              <td>{s.hit ? "✓ hit" : "✗ miss"}</td>
              <td class="stat-sub">{s.basis}</td>
            </tr>
          ))}
        </tbody>
      </table>
      </div>
    </>
  ) : (
    <p class="lede">
      No forecasted case has been scored yet — {card?.awaiting_decision ?? pending.length} forecasts
      are on the record (timestamped in git) and will be scored automatically as decisions land.
      {(card?.unscoreable?.length ?? 0) > 0 && (
        <> One resolved case ({card.unscoreable[0].name}) was excluded as not ex-ante —
        its forecast was regenerated after the decision — rather than counted.</>
      )}
    </p>
  )}
  {pa && (
    <>
      <h2>Post-argument track</h2>
      {pa.summary ? (
        <div class="kpis">
          <StatTile label="Cases scored" value={pa.summary.cases_scored} sub={`${pa.awaiting_decision} still pending`} />
          <StatTile label="Case accuracy" value={pct(pa.summary.case_accuracy, 1)} sub={`Brier ${pa.summary.case_brier}`} />
          {pa.summary.justice_vote_accuracy != null && (
            <StatTile label="Justice-vote accuracy" value={pct(pa.summary.justice_vote_accuracy, 1)} sub={`${pa.summary.justice_votes_scored} votes scored`} />
          )}
        </div>
      ) : (
        <p class="lede">
          {pa.awaiting_decision} argued case{pa.awaiting_decision === 1 ? "" : "s"} carry a
          second, transcript-informed forecast — scored separately, so this track measures
          what argument information is worth.
        </p>
      )}
    </>
  )}

  {ordered.map((p) => {
    const fc = forecastOf.get(p.id);
    const fc2 = stage2Of.get(p.id);   // post-argument re-registration, if argued
    const live = fc2 ?? fc;           // freshest stage drives votes/splits
    return (
      <section class="card fc-card">
        <div class="fc-head">
          <div>
            {p.oyez_url
              ? <a class="fc-title" href={p.oyez_url} target="_blank" rel="noopener">{caseTitle(p.name)}</a>
              : <span class="fc-title">{caseTitle(p.name)}</span>}
            <span class="stat-sub" style="margin-left:10px">{p.docket} · {p.term} term</span>
          </div>
          <span class="chip">{statusOf(p)}</span>
        </div>
        {p.question && <p class="fc-question">{clip(p.question, 300)}</p>}
        {live ? (
          <>
            <div class="fc-forecast">
              {fc2 && (
                <div class="fc-hero">
                  <div class="stat-label">P(reverse) · post-argument</div>
                  <div class="stat-value">{Math.round(fc2.prediction.p_reverse * 100)}%</div>
                </div>
              )}
              {fc && (
                <div class="fc-hero">
                  <div class="stat-label">{fc2 ? "at cert (frozen)" : "P(reverse)"}</div>
                  <div class="stat-value" style={fc2 ? "opacity:.55" : ""}>{Math.round(fc.prediction.p_reverse * 100)}%</div>
                </div>
              )}
              <div class="fc-meta">
                <div>expected reverse votes: <b>{live.prediction.expected_reverse_votes}</b> of {live.votes.length}</div>
                <div class="chips" style="margin-top:6px">
                  {topSplits(live).map(([split, prob]) => (
                    <span class="chip">{split.replace("-", "–")} · {Math.round(prob * 100)}%</span>
                  ))}
                </div>
              </div>
            </div>
            <details class="tableview">
              <summary>Per-justice forecast{fc2 ? " (post-argument)" : ""}</summary>
              <table class="data">
                <thead>
                  <tr><th>Justice</th><th class="n">P(reverse)</th><th>Predicted lean</th><th class="n">P(liberal)</th></tr>
                </thead>
                <tbody>
                  {live.votes.map((v) => {
                    const j = justiceOf.get(v.justice);
                    return (
                      <tr>
                        <td>{j ? <a href={url(`/justices/${j.slug}`)}>{j.name}</a> : v.justice}</td>
                        <td class="n">{pct(v.p_reverse)}</td>
                        <td>
                          <span class="dbar" role="img" aria-label={`${pct(v.p_liberal)} liberal`}>
                            {v.p_liberal >= 0.5
                              ? <span class="fill lib" style={`width:${((v.p_liberal - 0.5) * 100).toFixed(1)}%`}></span>
                              : <span class="fill con" style={`width:${((0.5 - v.p_liberal) * 100).toFixed(1)}%`}></span>}
                          </span>
                        </td>
                        <td class="n">{pct(v.p_liberal)}</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </details>
          </>
        ) : (
          <p class="stat-sub">No forecast generated for this case yet.</p>
        )}
      </section>
    );
  })}

  <h2>Method, briefly</h2>
  <p class="lede">
    Gradient-boosted trees over leak-free features (every justice-level input is computed
    from terms strictly before the prediction; nothing downstream of the vote is used).
    Validation is walk-forward by term — train on everything before term T, predict term T,
    repeat 1956–2024 — against base-rate, justice-history, and attitudinal baselines with
    exact McNemar tests. Case probabilities aggregate the nine per-justice probabilities
    with a two-factor coalition model (shared valence + signed-ideology factors,
    marginals preserved exactly) — validated to cut split-distribution log-loss 45%
    versus independence and improve binary outcomes too. Ideal-point trajectories
    (a penalized-ML Martin–Quinn variant, with bootstrap standard errors) live on each
    justice's page and in <code>data/scores/</code>.
  </p>
</Base>

<style>
  .fc-card { margin-bottom: 14px; }
  .fc-head { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; flex-wrap: wrap; }
  .fc-title { font-weight: 650; font-size: 16px; }
  .fc-question { color: var(--ink-2); font-size: 13.5px; max-width: 82ch; margin: 8px 0 10px; }
  .fc-forecast { display: flex; gap: 26px; align-items: center; flex-wrap: wrap; }
  .fc-hero .stat-value { font-size: 30px; }
  .fc-meta { font-size: 13.5px; color: var(--ink-2); }
</style>
