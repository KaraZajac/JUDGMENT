---
import "../styles/global.css";
import { meta } from "../lib/data.js";
import { url } from "../lib/format.js";

const { title = "JUDGMENT", description = "" } = Astro.props;
const m = meta();
const path = Astro.url.pathname;
const current = (p) =>
  (path === url(p) || path.startsWith(url(p) + "/") ? "true" : undefined);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    {description && <meta name="description" content={description} />}
    <title>{title} · JUDGMENT</title>
    <script is:inline src={url("/tooltip.js")} defer></script>
  </head>
  <body>
    <header class="site-head">
      <div class="wrap">
        <a class="brand" href={url("/")}>JUDGMENT</a>
        <nav class="site-nav">
          <a href={url("/predict")} aria-current={current("/predict")}>Predict</a>
          <a href={url("/justices")} aria-current={current("/justices")}>Justices</a>
          <a href={url("/terms")} aria-current={current("/terms")}>Terms</a>
          <a href={url("/courts")} aria-current={current("/courts")}>Courts</a>
          <a href={url("/about")} aria-current={current("/about")}>About</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site-foot">
      <div class="wrap">
        <div>
          {m.counts.cases.toLocaleString("en-US")} cases · {m.counts.vote_records.toLocaleString("en-US")}
          justice votes · terms {m.counts.first_term}–{m.counts.last_term} · SCDB
          {m.scdb.modern_release} + {m.scdb.legacy_release}
        </div>
        <div>
          Data derived from the Supreme Court Database (Spaeth, Epstein, Martin, Segal, Ruger &
          Benesh) — free for research use with attribution. Directional coding follows SCDB
          conventions. Research/educational use only.
        </div>
      </div>
    </footer>
  </body>
</html>
